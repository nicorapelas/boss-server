{
  "name": "electropos-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev-persistent.sh",
    "dev:watch": "NODE_ENV=development tsx watch src/index.ts",
    "dev:local": "NODE_ENV=development tsx scripts/dev-with-mongo.ts",
    "dev:persistent": "bash scripts/dev-persistent.sh",
    "migrate:vector:items": "NODE_ENV=development tsx scripts/migrate-vector-items.ts",
    "migrate:vector:items:embedded": "NODE_ENV=development tsx scripts/migrate-vector-items.ts --embedded-mongo",
    "migrate:vector:users": "NODE_ENV=development tsx scripts/migrate-vector-users.ts",
    "migrate:vector:sales": "NODE_ENV=development tsx scripts/migrate-vector-sales.ts",
    "migrate:vector:laybys": "NODE_ENV=development tsx scripts/migrate-vector-laybys.ts",
    "normalize:sku:vector": "NODE_ENV=development tsx scripts/normalize-vector-sku.ts",
    "repair:user-roles": "NODE_ENV=development tsx scripts/repair-user-roles.ts",
    "restore:store": "NODE_ENV=development tsx scripts/restore-store-backup.ts",
    "backup:mongo:cloud": "NODE_ENV=production tsx scripts/mongo-cloud-backup.ts",
    "clear:sales": "NODE_ENV=development tsx scripts/clear-sales-data.ts",
    "untrack:labour": "NODE_ENV=development tsx scripts/untrack-labour-products.ts",
    "fix:negative-stock": "NODE_ENV=development tsx scripts/fix-negative-stock.ts",
    "seed:bicycle-labour-presets": "NODE_ENV=development tsx scripts/seed-bicycle-labour-presets.ts",
    "seed:watch-labour-presets": "NODE_ENV=development tsx scripts/seed-watch-labour-presets.ts",
    "seed:watch-spares-pins-presets": "NODE_ENV=development tsx scripts/seed-watch-spares-pins-presets.ts",
    "seed:watch-spares-glasses-presets": "NODE_ENV=development tsx scripts/seed-watch-spares-glasses-presets.ts",
    "dev:local:vector": "NODE_ENV=development tsx scripts/dev-with-mongo-vector.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mdb-reader": "^3.2.0",
    "mongoose": "^8.8.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "mongodb-memory-server": "^10.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
