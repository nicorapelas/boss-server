# Optional: NODE_ENV selects config/development.json vs config/production.json (defaults to development)
# NODE_ENV=development

# Overrides (optional) — values here win over the JSON config files
# PORT=4000
# MONGODB_URI=mongodb://127.0.0.1:27017/electropos
# ACCESS_TOKEN_SECRET=
# REFRESH_TOKEN_SECRET=
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production: set NODE_ENV=production and provide secrets via env or your host’s secret store — not in git.
