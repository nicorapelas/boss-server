# Optional: NODE_ENV selects config/development.json vs config/production.json (defaults to development)
# NODE_ENV=development
#
# First-time setup (server/config/ is not in git):
#   cp config/development.example.json config/development.json
#   cp config/production.example.json config/production.json   # on production host only
# Env vars override values in those JSON files.

# Overrides (optional) — values here win over the JSON config files
# PORT=4000
# MONGODB_URI=mongodb://127.0.0.1:27017/electropos
# ACCESS_TOKEN_SECRET=
# REFRESH_TOKEN_SECRET=
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB cloud backup (off-site mirror via mongodump → mongorestore)
# Required for manual "Backup to cloud" in Back Office:
# MONGO_CLOUD_BACKUP_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# Optional — turn on daily schedule at mongoCloudBackup.schedule (default 13:00):
# MONGO_CLOUD_BACKUP_ENABLED=true
# MONGO_CLOUD_BACKUP_SCHEDULE=13:00
# MONGO_CLOUD_BACKUP_DATABASE=electropos
# MONGO_CLOUD_BACKUP_DOCKER_CONTAINER=electropos-mongo
#
# Note: npm run dev reads development.json; production uses production.json + env.

# Production: set NODE_ENV=production and provide secrets via env or your host’s secret store — not in git.
